model Availability {
  id           String    @id @default(uuid())
  technicianId String
  dayOfWeek    DayOfWeek
  startTime    DateTime 
  endTime      DateTime
  isBooked     Boolean   @default(false)
  createdAt    DateTime  @default(now())
  
//   Relations :
  technician TechnicianProfile @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  @@index([technicianId])
  @@map("availability")
}
